{
  "name": "vexel",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "config",
    "server",
    "client",
    "modules/*"
  ],
  "scripts": {
    "dev": "docker compose up -d --wait postgres && turbo dev",
    "dev:server": "turbo -F server dev",
    "dev:web": "turbo -F web dev",
    "build": "turbo build",
    "build:server": "turbo -F server build",
    "build:web": "turbo -F web build",
    "start": "turbo start",
    "start:server": "turbo -F server start",
    "start:web": "turbo -F web start",
    "db:push": "turbo -F @app/db db:push",
    "db:generate": "turbo -F @app/db db:generate",
    "db:migrate": "turbo -F @app/db db:migrate",
    "db:studio": "turbo -F @app/db db:studio",
    "typecheck": "turbo typecheck",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "check": "bun typecheck && bun lint"
  },
  "catalog": {
    "typescript": "^5.9.3",
    "@types/bun": "^1.3.10",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "turbo": "^2.8.16"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/bun": "^1.3.10",
    "@biomejs/biome": "2.4.6",
    "ultracite": "7.3.0"
  }
}
