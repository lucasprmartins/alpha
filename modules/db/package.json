{
  "name": "@app/db",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate --name=migration",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "catalog:",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@app/config": "workspace:*",
    "typescript": "catalog:",
    "@types/bun": "catalog:",
    "postgres": "^3.4.7",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1"
  }
}
